From: Developer <dev@amlogic.com>
Date: Thu, 5 Mar 2024 00:00:00 +0000
Subject: [PATCH] gst-v4l2: Add AMLOGIC_YYUV_10BIT_PACKED format support

Add support for V4L2_PIX_FMT_AMLOGIC_YYUV_10BIT_PACKED format in
GStreamer v4l2src plugin.

This enables capture of Amlogic VDIN 40-bit packed YUV422 10-bit format
directly from v4l2src element.

Changes:
- Add V4L2_PIX_FMT_AMLOGIC_YYUV_10BIT_PACKED to v4l2 header extension
- Register format in gstv4l2object.c format table
- Add V4L2 to GStreamer format conversion
- Handle in caps structure generation

Signed-off-by: Developer <dev@amlogic.com>
---
 sys/v4l2/ext/videodev2.h |  3 +++
 gstv4l2object.c         | 12 ++++++++++++
 2 files changed, 15 insertions(+)

diff --git a/sys/v4l2/ext/videodev2.h b/sys/v4l2/ext/videodev2.h
index 1234567..abcdefg 100644
--- a/sys/v4l2/ext/videodev2.h
+++ b/sys/v4l2/ext/videodev2.h
@@ -412,6 +412,9 @@ struct v4l2_pix_format {
 #define V4L2_PIX_FMT_P010    v4l2_fourcc('P', '0', '1', '0') /* 24  Y/CbCr 4:2:0 10-bit */
 #define V4L2_PIX_FMT_P012    v4l2_fourcc('P', '0', '1', '2') /* 24  Y/CbCr 4:2:0 12-bit */
 
+/* Amlogic specific formats */
+#define V4L2_PIX_FMT_AMLOGIC_YYUV_10BIT_PACKED v4l2_fourcc('A', 'M', 'Y', 'Y') /* 40  YUV422 10-bit packed */
+
 /* Vendor specific formats */
 #define V4L2_PIX_FMT_CPIA1    v4l2_fourcc('C', 'P', 'I', 'A')
 #define V4L2_PIX_FMT_WNVA     v4l2_fourcc('W', 'N', 'V', 'A')
diff --git a/gstv4l2object.c b/gstv4l2object.c
index 1234567..abcdefg 100644
--- a/gstv4l2object.c
+++ b/gstv4l2object.c
@@ -285,6 +285,8 @@ static const GstV4L2FormatDesc gst_v4l2_formats[] = {
   {V4L2_PIX_FMT_NV24, TRUE, GST_V4L2_RAW},
   /* 10-bit YUV 4:2:0 format for HDR */
   {V4L2_PIX_FMT_P010, TRUE, GST_V4L2_RAW},
+  /* Amlogic 40-bit packed YUV422 10-bit */
+  {V4L2_PIX_FMT_AMLOGIC_YYUV_10BIT_PACKED, TRUE, GST_V4L2_RAW},
 
   /* compressed formats */
 #ifndef GST_V4L2_DISABLE_DEPRECATED
@@ -1345,6 +1347,9 @@ gst_v4l2_object_v4l2fourcc_to_videoformat (guint32 fourcc)
     case V4L2_PIX_FMT_P010:
       format = GST_VIDEO_FORMAT_P010_10LE;
       break;
+    case V4L2_PIX_FMT_AMLOGIC_YYUV_10BIT_PACKED:
+      format = GST_VIDEO_FORMAT_AMLOGIC_YYUV_10BIT_PACKED;
+      break;
 
     /* compressed formats */
     case V4L2_PIX_FMT_MJPEG:
@@ -1712,6 +1717,7 @@ gst_v4l2_object_v4l2fourcc_to_bare_struct (guint32 fourcc)
     case V4L2_PIX_FMT_NV24:    /* 24  Y/CrCb 4:4:4  */
     case V4L2_PIX_FMT_P010:    /* 24  Y/CbCr 4:2:0 10-bit */
+    case V4L2_PIX_FMT_AMLOGIC_YYUV_10BIT_PACKED:  /* 40  YUV422 10-bit packed */
     case V4L2_PIX_FMT_YVU410:
     case V4L2_PIX_FMT_YUV410:
     case V4L2_PIX_FMT_YUV420:  /* I420 */