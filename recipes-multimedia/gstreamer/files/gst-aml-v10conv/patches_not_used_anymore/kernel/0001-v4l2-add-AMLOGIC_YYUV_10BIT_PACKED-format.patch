From: Developer <dev@amlogic.com>
Date: Thu, 5 Mar 2024 00:00:00 +0000
Subject: [PATCH 1/3] media: v4l2: Add AMLOGIC_YYUV_10BIT_PACKED format support

Add V4L2 pixel format for Amlogic VDIN 40-bit packed YUV422 10-bit output.
This is the native output format from Amlogic VDIN hardware when capturing
10-bit YUV422 video.

The format uses 40 bits per 2 pixels (5 bytes per 2 pixels):
- Byte layout: U(10) + Y0(10) + V(10) + Y1(10) packed in 5 bytes
- Little-endian byte order
- Total: 2.5 bytes per pixel

Signed-off-by: Developer <dev@amlogic.com>
---
 include/uapi/linux/videodev2.h | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/include/uapi/linux/videodev2.h b/include/uapi/linux/videodev2.h
index 1234567..abcdefg 100644
--- a/include/uapi/linux/videodev2.h
+++ b/include/uapi/linux/videodev2.h
@@ -612,6 +612,9 @@ struct v4l2_pix_format {
 #define V4L2_PIX_FMT_P010    v4l2_fourcc('P', '0', '1', '0') /* 24  Y/CbCr 4:2:0 10-bit */
 #define V4L2_PIX_FMT_P012    v4l2_fourcc('P', '0', '1', '2') /* 24  Y/CbCr 4:2:0 12-bit */
 
+/* Amlogic specific formats */
+#define V4L2_PIX_FMT_AMLOGIC_YYUV_10BIT_PACKED v4l2_fourcc('A', 'M', 'Y', 'Y') /* 40  YUV422 10-bit packed */
+
 /* Vendor specific formats */
 #define V4L2_PIX_FMT_CPIA1    v4l2_fourcc('C', 'P', 'I', 'A')
 #define V4L2_PIX_FMT_WNVA     v4l2_fourcc('W', 'N', 'V', 'A')